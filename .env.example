# Go API backend
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=info

OSRM_BASE_URL=https://router.project-osrm.org
OSRM_TIMEOUT=20s

OPTIMIZER_TIMEOUT=10s

# Location search (OpenStreetMap Nominatim)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=kasi-delivery/1.0 (contact: you@example.com)
GEOCODE_TIMEOUT=10s

# H3 hex resolution (0-15; 9 ~ 174m edge, good for city deliveries)
H3_RESOLUTION=9

HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=15s

# Optional: only needed if the browser calls the API on a different origin
# (the Next.js dev/prod proxy makes this unnecessary in the default setup)
ALLOWED_ORIGIN=

# Next.js frontend: where it proxies /api/* to (defaults to http://localhost:8080)
BACKEND_URL=http://localhost:8080
