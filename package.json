{
  "name": "kasi-delivery",
  "version": "1.0.0",
  "private": true,
  "description": "Kasi Delivery — Go route-optimization API + Next.js dispatcher dashboard",
  "scripts": {
    "postinstall": "npm --prefix frontend install",
    "dev": "concurrently --kill-others --names \"API,WEB\" --prefix-colors \"green.bold,cyan.bold\" \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cd . && go run ./cmd/server",
    "dev:web": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build && go build -o bin/dispatch-ops ./cmd/server",
    "test": "go test ./...",
    "start:api": "go run ./cmd/server",
    "start:web": "npm --prefix frontend run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
